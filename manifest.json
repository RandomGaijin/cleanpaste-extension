{
    "manifest_version": 3,
    "name": "CleanPaste",
    "version": "1.0",
    "description": "Clean messy copied text before pasting.",
    "permissions": [
        "clipboardRead",
        "clipboardWrite"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "CleanPaste"
    }
}