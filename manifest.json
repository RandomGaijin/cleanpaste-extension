{
    "manifest_version": 3,
    "name": "CleanPaste",
    "version": "1.0",
    "description": "Clean messy copied text before pasting.",
    "permissions": [
        "clipboardRead",
        "clipboardWrite"
    ],
    "icons": {
        "32": "icon32.png",
        "64": "icon64.png",
        "128": "icon128.png"
    },


    "action": {
        "default_icon": {
            "32": "icon32.png",
            "64": "icon64.png",
            "128": "icon128.png"
        },
        "default_popup": "popup.html",
        "default_title": "CleanPaste"
    }
}